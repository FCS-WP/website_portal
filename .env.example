# Repo-root .env — read by docker-compose for port mappings + Postgres init.
# Copy to .env on a fresh checkout:
#   cp .env.example .env
# `make setup` does this automatically.

# Host-side port mappings. Inside the docker network containers always use
# their default ports; these are the bindings on your laptop.
APP_PORT=8000
FRONTEND_PORT=3000
POSTGRES_PORT=8081
# Host port 6379 is often taken by a local Redis; map ours to 6380 by default.
REDIS_PORT=6380

# Postgres init credentials. These ALSO have to match DB_USERNAME / DB_PASSWORD
# / DB_DATABASE in portal/.env — portal/.env is what Laravel reads, this file
# is what docker-compose passes to the postgres image on first boot.
DB_DATABASE=epos_portal
DB_USERNAME=epos
DB_PASSWORD=epos_secret
