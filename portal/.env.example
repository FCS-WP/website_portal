APP_NAME="Website Portal"
APP_ENV=local
# Run `make artisan cmd="key:generate"` after copying this file to .env.
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ─── Database ────────────────────────────────────────────────────────────────
# Postgres runs inside the docker network as service "postgres". The
# credentials here must match the ones in the repo-root .env (which docker-
# compose passes to the postgres image during init).
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=epos_portal
DB_USERNAME=epos
DB_PASSWORD=epos_secret

# ─── Session / Cache / Queue ─────────────────────────────────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

# ─── Redis ───────────────────────────────────────────────────────────────────
# Container hostname inside the docker network. The host port 6380 in the
# root .env is only for connecting from your laptop; in-cluster traffic uses
# the default 6379.
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# ─── Mail ────────────────────────────────────────────────────────────────────
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# ─── AWS (optional, for S3-backed plugin storage) ───────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ─── Telegram notifications ──────────────────────────────────────────────────
# Fill these in to receive deployment + spike alerts. Settings → Telegram
# in the UI is the easier path; this is the env fallback.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_TOPIC_ID=

# ─── CORS / SPA auth ─────────────────────────────────────────────────────────
# Comma-separated list. Frontend dev server runs on http://localhost:3000.
CORS_ALLOWED_ORIGINS=http://localhost:3000
SANCTUM_STATEFUL_DOMAINS=localhost:3000,127.0.0.1:3000

VITE_APP_NAME="${APP_NAME}"

# ─── Default admin user (DatabaseSeeder) ─────────────────────────────────────
# Fill these before running `make migrate-fresh` or the seeder will throw.
# Keep the password out of version control — change it before deploying.
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
SEED_ADMIN_NAME=Admin

# ─── EPOS agent integration ─────────────────────────────────────────────────
# URL that WordPress sites (epos-wp-agent plugin) use to reach this backend.
# Defaults to APP_URL if unset. For a WP container on the same docker host
# but a different network, use http://host.docker.internal:8000.
PORTAL_BASE_URL=

# ─── Vault encryption ────────────────────────────────────────────────────────
# Master key for the credential vault. 64-char hex (32 bytes). REQUIRED for
# sync-credentials / site_credentials features. Generate with:
#   docker-compose exec app php -r 'echo bin2hex(random_bytes(32));'
# Do NOT change after data has been encrypted — old rows become unreadable.
VAULT_MASTER_KEY=
