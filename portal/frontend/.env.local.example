# Frontend (Next.js) dev env. Copy to .env.local for local development:
#   cp .env.local.example .env.local
# `make setup` does this automatically.
#
# The Next dev server runs INSIDE the docker `frontend` container, so paths
# like http://localhost:8000 don't resolve — they'd point at the container
# itself. Use the docker service name `nginx` (which fronts the Laravel app)
# for the proxy target.

# What the browser actually fetches. We keep it relative so cookies/CSRF
# stay same-origin; the Next dev server proxies these to API_PROXY_TARGET.
NEXT_PUBLIC_API_URL=/api

# Target of the /api/* proxy. Docker service name on the shared network.
API_PROXY_TARGET=http://nginx
